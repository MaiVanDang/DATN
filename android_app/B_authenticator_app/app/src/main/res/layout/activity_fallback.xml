<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_fallback"
    android:padding="32dp"
    android:gravity="center"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/fallbackTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/fallback_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/state_unknown"
        android:gravity="center"/>

    <TextView
        android:id="@+id/fallbackStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/fallback_status"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"/>

    <TextView
        android:id="@+id/fallbackCounter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="96sp"
        android:textStyle="bold"
        android:textColor="@color/state_unknown"
        android:gravity="center"
        android:layout_marginTop="32dp"
        xmlns:tools="http://schemas.android.com/tools"
        tools:ignore="HardcodedText"/>

    <Button
        android:id="@+id/btnStartShake"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/btn_start_shake"/>

    <Button
        android:id="@+id/btnDoneShake"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/btn_done_shake"/>

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/btn_cancel"/>
</LinearLayout>
