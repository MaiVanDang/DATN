<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <!-- Auth status bar (always visible at top) -->
    <LinearLayout
        android:id="@+id/quizStatusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#E8F5E9"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác thực: "
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/quizTvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRUSTED"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/state_trusted" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/quizTvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tin cậy: —"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Quiz content scrollable area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bài kiểm tra kiến thức"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hệ thống xác thực hành vi đang chạy ngầm trong khi bạn làm bài."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="20dp" />

            <!-- Question card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/bg_card"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/quizTvQuestionNum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Câu 1 / 5"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/quizTvQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="16dp" />

                <RadioGroup
                    android:id="@+id/quizRgAnswers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/quizRb1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/quizRb2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/quizRb3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/quizRb4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="15sp" />
                </RadioGroup>

                <TextView
                    android:id="@+id/quizTvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:lineSpacingMultiplier="1.3"
                    android:visibility="gone" />
            </LinearLayout>

            <Button
                android:id="@+id/quizBtnNext"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Xác nhận"
                android:textSize="16sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp" />

            <!-- Keystroke collection area -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ghi chú / Nhận xét:"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/quizEtNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập suy nghĩ của bạn về câu hỏi vừa trả lời..."
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top"
                android:padding="10dp" />

            <TextView
                android:id="@+id/quizTvKeyStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:text="Tap: 0  |  Cuộn: 0  |  Phím: 0" />

            <!-- Re-enroll button (bottom) -->
            <Button
                android:id="@+id/quizBtnReenroll"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Đăng ký lại (xoá hồ sơ)"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
